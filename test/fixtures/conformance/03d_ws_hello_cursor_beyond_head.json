{
  "name": "ws hello: a cursor beyond the journal head replays nothing and stays connected",
  "description": "head_seq is 3; hello with cursor:10 (beyond head) is not an error and does not trip snapshot_required (the gap is negative) — it just replays zero events and still registers live: a subsequent live publish is delivered normally.",
  "seed": {
    "users": [{ "as": "dan", "name": "dan", "password": "fixture-pw-5" }],
    "agents": [{ "as": "bridge", "user": "dan", "name": "dev-2" }],
    "conversations": [{ "id": "c1", "owner": "dan" }],
    "events": [
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m0" } },
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m1" } },
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m2" } }
    ]
  },
  "steps": [
    { "kind": "http", "method": "POST", "path": "/login",
      "body": { "username": "dan", "password": "fixture-pw-5", "device_name": "mac" },
      "expect": { "status": 200, "body": {
        "token": { "$bind": "dan_token" }, "device_id": { "$type": "integer" }, "user_id": { "$ref": "dan.user_id" }
      } } },

    { "kind": "ws_open", "conn": "client" },
    { "kind": "ws_send", "conn": "client", "frame": { "op": "hello", "token": { "$ref": "dan_token" }, "cursor": 10 } },
    { "kind": "ws_expect", "conn": "client", "frame": { "kind": "control", "op": "hello_ok", "seq": 3 } },
    { "kind": "ws_expect_none", "conn": "client", "ms": 150 },

    { "kind": "ws_open", "conn": "agent" },
    { "kind": "ws_send", "conn": "agent", "frame": { "op": "hello", "token": { "$ref": "bridge.token" }, "cursor": null } },
    { "kind": "ws_expect", "conn": "agent", "frame": { "kind": "control", "op": "hello_ok", "seq": 3 } },
    { "kind": "ws_send", "conn": "agent", "frame": { "op": "publish", "convo_id": "c1", "type": "text", "payload": { "body": "still alive" } } },

    { "kind": "ws_expect", "conn": "client", "frame": {
      "kind": "journal", "seq": 4, "convo_id": "c1", "ts": { "$type": "integer" },
      "sender": "agent:dev-2", "type": "text", "payload": { "body": "still alive" }
    } }
  ]
}
