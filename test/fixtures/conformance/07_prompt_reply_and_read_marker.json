{
  "name": "prompt_reply shape, read_marker (explicit seq and null-to-head), unread reset, agent read_marker allowed",
  "description": "A client prompt_reply carries {target_seq, choice, text} (text defaults to null when omitted). read_marker with an explicit up_to_seq resets unread for everything up to that seq; up_to_seq:null resolves server-side to the conversation's current head. An agent connection may also send read_marker on the user's behalf (sender agent:<name> instead of user:<name>) — e.g. after mirroring the user's own message.",
  "seed": {
    "users": [{ "as": "dan", "name": "dan", "password": "fixture-pw-11" }],
    "agents": [{ "as": "bridge", "user": "dan", "name": "dev-2" }],
    "conversations": [{ "id": "c1", "owner": "dan" }]
  },
  "steps": [
    { "kind": "http", "method": "POST", "path": "/login",
      "body": { "username": "dan", "password": "fixture-pw-11", "device_name": "mac" },
      "expect": { "status": 200, "body": {
        "token": { "$bind": "dan_token" }, "device_id": { "$type": "integer" }, "user_id": { "$ref": "dan.user_id" }
      } } },
    { "kind": "ws_open", "conn": "agent" },
    { "kind": "ws_send", "conn": "agent", "frame": { "op": "hello", "token": { "$ref": "bridge.token" }, "cursor": null } },
    { "kind": "ws_expect", "conn": "agent", "frame": { "kind": "control", "op": "hello_ok", "seq": 0 } },
    { "kind": "ws_open", "conn": "client" },
    { "kind": "ws_send", "conn": "client", "frame": { "op": "hello", "token": { "$ref": "dan_token" }, "cursor": 0 } },
    { "kind": "ws_expect", "conn": "client", "frame": { "kind": "control", "op": "hello_ok", "seq": 0 } },

    { "kind": "ws_send", "conn": "agent", "frame": { "op": "publish", "convo_id": "c1", "type": "prompt",
      "payload": { "question": "ship it?", "options": ["yes", "no"], "allows_free_text": false } } },
    { "kind": "ws_expect", "conn": "client", "frame": {
      "kind": "journal", "seq": { "$bind": "prompt_seq" }, "convo_id": "c1", "ts": { "$type": "integer" },
      "sender": "agent:dev-2", "type": "prompt",
      "payload": { "question": "ship it?", "options": ["yes", "no"], "allows_free_text": false }
    } },
    { "kind": "http", "method": "GET", "path": "/snapshot", "token": { "$ref": "dan_token" },
      "expect": { "status": 200, "body": { "seq": { "$ref": "prompt_seq" }, "conversations": [
        { "id": "c1", "title": "", "session_state": "running", "last_seq": { "$ref": "prompt_seq" },
          "unread_count": 1, "snippet": "? ship it?", "created_at": { "$type": "integer" }, "last_ts": { "$type": "integer" } }
      ] } } },

    { "kind": "ws_send", "conn": "client", "frame": { "op": "prompt_reply", "convo_id": "c1", "target_seq": { "$ref": "prompt_seq" }, "choice": "yes" } },
    { "kind": "ws_expect", "conn": "client", "frame": {
      "kind": "journal", "seq": 2, "convo_id": "c1", "ts": { "$type": "integer" },
      "sender": "user:dan", "type": "prompt_reply", "payload": { "target_seq": { "$ref": "prompt_seq" }, "choice": "yes", "text": null }
    } },

    { "kind": "ws_send", "conn": "client", "frame": { "op": "read_marker", "convo_id": "c1", "up_to_seq": { "$ref": "prompt_seq" } } },
    { "kind": "ws_expect", "conn": "client", "frame": {
      "kind": "journal", "seq": 3, "convo_id": "c1", "ts": { "$type": "integer" },
      "sender": "user:dan", "type": "read_marker", "payload": { "convo_id": "c1", "up_to_seq": { "$ref": "prompt_seq" } }
    } },

    { "kind": "ws_send", "conn": "agent", "frame": { "op": "publish", "convo_id": "c1", "type": "text", "payload": { "body": "building..." } } },
    { "kind": "ws_expect", "conn": "client", "frame": {
      "kind": "journal", "seq": 4, "convo_id": "c1", "ts": { "$type": "integer" },
      "sender": "agent:dev-2", "type": "text", "payload": { "body": "building..." }
    } },
    { "kind": "ws_send", "conn": "client", "frame": { "op": "read_marker", "convo_id": "c1", "up_to_seq": null } },
    { "kind": "ws_expect", "conn": "client", "frame": {
      "kind": "journal", "seq": 5, "convo_id": "c1", "ts": { "$type": "integer" },
      "sender": "user:dan", "type": "read_marker", "payload": { "convo_id": "c1", "up_to_seq": 4 }
    } },

    { "kind": "ws_send", "conn": "agent", "frame": { "op": "publish", "convo_id": "c1", "type": "text", "payload": { "body": "done" } } },
    { "kind": "ws_expect", "conn": "client", "frame": {
      "kind": "journal", "seq": 6, "convo_id": "c1", "ts": { "$type": "integer" },
      "sender": "agent:dev-2", "type": "text", "payload": { "body": "done" }
    } },
    { "kind": "ws_send", "conn": "agent", "frame": { "op": "read_marker", "convo_id": "c1", "up_to_seq": null } },
    { "kind": "ws_expect", "conn": "client", "frame": {
      "kind": "journal", "seq": 7, "convo_id": "c1", "ts": { "$type": "integer" },
      "sender": "agent:dev-2", "type": "read_marker", "payload": { "convo_id": "c1", "up_to_seq": 6 }
    } },

    { "kind": "http", "method": "GET", "path": "/snapshot", "token": { "$ref": "dan_token" },
      "expect": { "status": 200, "body": { "seq": 7, "conversations": [
        { "id": "c1", "title": "", "session_state": "running", "last_seq": 7,
          "unread_count": 0, "snippet": "done", "created_at": { "$type": "integer" }, "last_ts": { "$type": "integer" } }
      ] } } }
  ]
}
