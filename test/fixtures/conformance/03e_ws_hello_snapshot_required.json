{
  "name": "ws hello: a replay gap over MATRON_MAX_REPLAY sends snapshot_required and closes 4009",
  "description": "With the valve forced small (maxReplay:5) and a 10-event backlog, hello with cursor:0 (gap 10 > 5) gets hello_ok, then {kind:'control', op:'snapshot_required'} instead of any journal replay, then the socket closes with code 4009 — never registered live (spec §6 efficiency valve).",
  "server": { "maxReplay": 5 },
  "seed": {
    "users": [{ "as": "dan", "name": "dan", "password": "fixture-pw-6" }],
    "conversations": [{ "id": "c1", "owner": "dan" }],
    "events": [
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m0" } },
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m1" } },
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m2" } },
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m3" } },
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m4" } },
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m5" } },
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m6" } },
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m7" } },
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m8" } },
      { "convo": "c1", "sender": "agent:dev-2", "type": "text", "payload": { "body": "m9" } }
    ]
  },
  "steps": [
    { "kind": "http", "method": "POST", "path": "/login",
      "body": { "username": "dan", "password": "fixture-pw-6", "device_name": "mac" },
      "expect": { "status": 200, "body": {
        "token": { "$bind": "dan_token" }, "device_id": { "$type": "integer" }, "user_id": { "$ref": "dan.user_id" }
      } } },

    { "kind": "ws_open", "conn": "client" },
    { "kind": "ws_send", "conn": "client", "frame": { "op": "hello", "token": { "$ref": "dan_token" }, "cursor": 0 } },
    { "kind": "ws_expect", "conn": "client", "frame": { "kind": "control", "op": "hello_ok", "seq": 10 } },
    { "kind": "ws_expect", "conn": "client", "frame": { "kind": "control", "op": "snapshot_required" } },
    { "kind": "ws_expect_close", "conn": "client", "code": 4009 }
  ]
}
